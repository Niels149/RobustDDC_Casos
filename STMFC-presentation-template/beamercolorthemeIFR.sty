
\ProvidesPackage{beamercolorthemeIFR}
\mode<presentation>  % Invoke presentation mode

\definecolor{Orange}{RGB}{255,110,30}  % Caltech Orange!

\definecolor{renatoSblue}{RGB}{0,65,145}
\definecolor{uniSlightblue}{RGB}{114,218,255}
\definecolor{uniSgray}{RGB}{62, 68, 76}
\definecolor{uniSyellow}{RGB}{255, 213, 0}
\definecolor{greytext}{RGB}{62, 68, 76}


\setbeamercolor{palette primary}{bg=uniSgray!20,fg=uniSgray}
\setbeamercolor{palette tertiary}{fg=white}

\definecolor{Red}{HTML}{E53E30}  % "Pantone 179"
\definecolor{Green}{HTML}{00AD69}  % "Pantone 3405"
\definecolor{Blue}{HTML}{2171b5}

\definecolor{waitcolor}{RGB}{15, 48, 89}
\definecolor{Blue1}{HTML}{2171b5}
\definecolor{Purple}{HTML}{652F6C}  % "Pantone 520"
\definecolor{bostonuniversityred}{rgb}{0.8, 0.0, 0.0}
\definecolor{brown(web)}{rgb}{0.65, 0.16, 0.16}

\definecolor{White}{RGB}{255,255,255}
\definecolor{DarkGrey}{RGB}{118,119,123}
\definecolor{MediumGrey}{RGB}{200,200,200}
\definecolor{LightGrey}{RGB}{240,240,240}
\definecolor{Black}{RGB}{0,0,0}

\setbeamercolor{sidebar}{bg=LightGrey}

\setbeamercolor{titlelike}{fg=Orange,bg=LightGrey}
\setbeamercolor{titlelike}{fg=White,bg=Blue1}
\setbeamercolor{subtitle}{fg=Black,bg=Green}
\setbeamercolor{author}{fg=Black}
\setbeamercolor{date}{fg=Black}
\setbeamercolor{institute}{fg=Black}

%\setbeamercolor{frametitle}{fg=Orange,bg=LightGrey}
\setbeamercolor{frametitle}{fg=Blue,bg=LightGrey}
\setbeamercolor{framesubtitle}{fg=Green}

\setbeamercolor{normal text}{fg=Black}
\setbeamercolor{structure}{fg=Blue}
\setbeamercolor{alerted text}{fg=Red}
\setbeamercolor{example text}{fg=Green}

\setbeamercolor{block title}{use=structure,fg=White,bg=structure.fg!75!Black}
\setbeamercolor{block title alerted}{use=alerted text,fg=White,bg=alerted text.fg!75!Black}
\setbeamercolor{block title example}{use=example text,fg=White,bg=example text.fg!75!Black}

\setbeamercolor{block body}{bg=MediumGrey!25!White,fg=Black}
\setbeamercolor{block body alerted}{bg=MediumGrey!25!White,fg=Black}
\setbeamercolor{block body example}{bg=MediumGrey!25!White,fg=Black}

\setbeamercolor{section in toc}{fg=Black,bg=White}

\setbeamercolor{navigation symbols}{fg=Orange}

\mode<all>